# Streamlit Cloud secrets — copy this format into:
#   https://share.streamlit.io → your app → Settings → Secrets
#
# For local dev, copy to .streamlit/secrets.toml (gitignored via .env.* rule)

# Optional: enables Claude AI explanations
ANTHROPIC_API_KEY = "sk-ant-..."

# Optional: enables HuggingFace LLM as fallback
HF_TOKEN = "hf_..."
