# Copy this to .env for local development (never commit .env)

# Optional: enables AI-powered explanations (Anthropic Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: enables HuggingFace LLM as fallback
HF_TOKEN=your_huggingface_token_here

# Optional: custom path for the SQLite database
# DB_PATH=/data/rental_scam.db
