# Copy this to .env for local development (never commit .env)

# Optional: enables AI-powered explanations (Anthropic Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: enables HuggingFace LLM as fallback
HF_TOKEN=your_huggingface_token_here

# Optional: custom path for the SQLite database
# DB_PATH=/data/rental_scam.db

# SMTP — Gmail App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_gmail_app_password_here
SMTP_FROM=your_gmail_address@gmail.com

# PostgreSQL (used for auth & agent)
DATABASE_URL=postgresql+asyncpg://rentalguard:rentalguard_dev@localhost:5432/rentalguard

# JWT secrets — generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production-use-32-chars-min
JWT_REFRESH_SECRET=change-me-refresh-secret-32-chars-min

# Frontend URL (for CORS and email links)
APP_URL=http://localhost:3000
